#!/bin/bash
# aar-skills pre-commit: this repo is PUBLIC — block committing secrets or instance specifics.
# Install once per clone: git config core.hooksPath .githooks
#
# Committed here: GENERIC secret regexes only — no instance values (the rule this repo follows). Instance-
# specific patterns (your bucket name, IPs, volume IDs, handles) go in a LOCAL, gitignored file so they
# protect your commits WITHOUT entering the public history themselves — one regex per line, '#' comments ok:
#   printf 'r2:mybucket\n10\\.0\\.0\\.\n' > .githooks/patterns.local
PATTERNS='ghp_[A-Za-z0-9]|gho_[A-Za-z0-9]|ghu_[A-Za-z0-9]|ghs_[A-Za-z0-9]|github_pat_[A-Za-z0-9]|sk-ant-|sk-proj-|AKIA[A-Z0-9]{12}|-----BEGIN[A-Z ]*PRIVATE KEY|RUNPOD[A-Z_]*API_KEY=.+[A-Za-z0-9]|AIza[0-9A-Za-z_-]{20}|xox[baprs]-[A-Za-z0-9]'
ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
LOCAL="$ROOT/.githooks/patterns.local"
if [ -f "$LOCAL" ]; then
  extra=$(grep -vE '^[[:space:]]*(#|$)' "$LOCAL" | paste -sd '|' -)
  [ -n "$extra" ] && PATTERNS="$PATTERNS|$extra"
fi
FAILED=0
while read -r f; do
  [ -f "$f" ] || continue
  [ "$f" = ".githooks/pre-commit" ] && continue
  if git show ":$f" | grep -nE "$PATTERNS" >/dev/null 2>&1; then
    echo "BLOCKED: staged $f matches a secret/instance pattern:" >&2
    git show ":$f" | grep -nE "$PATTERNS" | head -3 >&2
    FAILED=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)
exit $FAILED
